# 触发测试 API 配置示例
# 复制此文件为 .env 并填入实际密钥

# ==============================================================================
# OpenAI 配置
# ==============================================================================
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4

# ==============================================================================
# z.ai 配置（OpenAI 兼容）
# ==============================================================================
# OPENAI_API_KEY=your-z-ai-api-key
# OPENAI_BASE_URL=https://api.z.ai/v1
# OPENAI_MODEL=deepseek-chat
#
# z.ai GLM-5.1：关闭推理（触发测试推荐，见 docs/user/TRIGGER-TESTING-MODELS.md）
# OPENAI_MODEL=GLM-5.1
# OPENAI_EXTRA_BODY={"thinking":{"type":"disabled"}}

# ==============================================================================
# 其他 OpenAI 兼容服务
# ==============================================================================

# vLLM (自托管)
# OPENAI_API_KEY=your-vllm-key
# OPENAI_BASE_URL=http://localhost:8000/v1
# OPENAI_MODEL=your-deployed-model

# Ollama (本地)
# OPENAI_API_KEY=ollama
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_MODEL=llama2

# Azure OpenAI
# OPENAI_API_KEY=your-azure-key
# OPENAI_BASE_URL=https://your-resource.openai.azure.com/openai/deployments/your-deployment
# OPENAI_MODEL=gpt-4

# ==============================================================================
# 使用方法
# ==============================================================================
# 1. 取消注释并填入相应服务的配置
# 2. 保存为 .env 文件
# 3. 运行测试：
#    python3 maintainer/scripts/evaluation/run_trigger_tests.py --mode api
#
# 环境变量优先级：
#   命令行参数 > 环境变量 > 默认值
#
# 示例：覆盖环境变量中的模型
#   python3 maintainer/scripts/evaluation/run_trigger_tests.py --mode api --model gpt-4
